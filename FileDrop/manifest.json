{
    "name": "File Drop",
    "version": "1.0.0",
    "manifest_version": 3,
    "description": "A simple extension to demonstrate file dropping",
    "action": {
        "default_icon": "assets/logo.png",
        "default_title": "File Drop Extension",
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "assets/icon16.png",
        "32": "assets/icon32.png",
        "48": "assets/icon48.png",
        "64": "assets/icon64.png",
        "128": "assets/icon128.png"
    },
    "permissions": [
        "activeTab",
        "storage"
    ]
}